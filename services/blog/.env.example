# Blog Service Environment Variables
PORT=5001

# Postgres Database connection string
DB_URL=postgresql://username:password@localhost:5432/dbname?sslmode=disable
DB_MAX_CONNS=25
DB_MIN_CONNS=5
DB_MAX_CONN_LIFETIME=30m
DB_MAX_CONN_IDLE_TIME=15m

# RabbitMQ configuration
Rabbitmq_Host=localhost
Rabbitmq_Username=guest
Rabbitmq_Password=guest

# Redis configuration (for saving blogs state/cache)
REDIS_URL=redis://localhost:6379

# User microservice base endpoint
USER_SERVICE=https://user-service-6ffj.onrender.com

# JWT authentication secret key
JWT_SECRET=your-super-secret-jwt-key
